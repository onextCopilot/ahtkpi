# Enable Rewrite Engine
RewriteEngine On
RewriteBase /

# Prevent directory browsing
Options -Indexes

# Protect config directory (only forbid direct requests)
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^config/ - [F,L]

# Protect includes directory
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^includes/ - [F,L]

# Protect modules directory from direct access
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^modules/ - [F,L]

# ============================================
# URL Rewriting Rules - Clean URLs
# ============================================

# Prevent rewrite loop for actual files
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Main Pages
RewriteRule ^login/?$ modules/auth/login.php [L]
RewriteRule ^logout/?$ modules/auth/logout.php [L]
RewriteRule ^dashboard/?$ modules/dashboard/dashboard.php [L]
RewriteRule ^profile/?$ modules/profile/index.php [L]

# Settings Pages
RewriteRule ^settings/?$ modules/settings/index.php [L]
RewriteRule ^settings/users/?$ modules/settings/users/index.php [L]
RewriteRule ^settings/users/edit/?$ modules/settings/users/edit.php [L]
RewriteRule ^settings/departments/?$ modules/settings/departments/index.php [L]
RewriteRule ^settings/core(-|_)members/?$ modules/settings/core_members/index.php [L]
RewriteRule ^settings/smtp/?$ modules/settings/smtp/index.php [L]
RewriteRule ^settings/odoo/?$ modules/settings/odoo/index.php [L]
RewriteRule ^settings/jira/?$ modules/settings/jira/index.php [L]
RewriteRule ^settings/teams/?$ modules/settings/teams/index.php [L]

# Application Modules
RewriteRule ^debt/?$ modules/debt/index.php [L]
RewriteRule ^my-debt/?$ modules/my_debt/index.php [L]
RewriteRule ^customers/?$ modules/customers/index.php [L]
RewriteRule ^invoices/?$ modules/invoices/index.php [L]
RewriteRule ^kpi/?$ modules/kpi/index.php [L]

# APIs
RewriteRule ^api/kpi_tab_order/?$ api/kpi_tab_order.php [L]
RewriteRule ^api/kpi_monthly_save/?$ api/kpi_monthly_save.php [L]
RewriteRule ^api/kpi_quarterly_save/?$ api/kpi_quarterly_save.php [L]

# Home/Index: / -> index.php
DirectoryIndex index.php

# ============================================
# Security Headers
# ============================================
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>

# ============================================
# PHP Settings
# ============================================
<IfModule mod_php.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 10M
    php_value max_execution_time 300
    php_value max_input_time 300
</IfModule>

# ============================================
# Error Pages (optional)
# ============================================
# ErrorDocument 404 /404.php
# ErrorDocument 403 /403.php
# ErrorDocument 500 /500.php
