# Enable Rewrite Engine
RewriteEngine On
RewriteBase /

# Prevent directory browsing
Options -Indexes

# Protect config directory (only forbid direct requests)
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^config/ - [F,L]

# Protect includes directory
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^includes/ - [F,L]

# ============================================
# URL Rewriting Rules - Clean URLs
# ============================================

# Prevent rewrite loop for actual files
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Main Pages
RewriteRule ^login/?$ modules/auth/login.php [L]
RewriteRule ^logout/?$ modules/auth/logout.php [L]
RewriteRule ^dashboard/?$ modules/dashboard/dashboard.php [L]
RewriteRule ^profile/?$ modules/profile/index.php [L]

# Settings Pages
RewriteRule ^settings/?$ modules/settings/index.php [L]
RewriteRule ^settings/users/?$ modules/settings/users/index.php [L]
RewriteRule ^settings/users/edit/?$ modules/settings/users/edit.php [L]
RewriteRule ^settings/departments/?$ modules/settings/departments/index.php [L]
RewriteRule ^settings/core(-|_)members/?$ modules/settings/core_members/index.php [L]
RewriteRule ^settings/smtp/?$ modules/settings/smtp/index.php [L]
RewriteRule ^settings/odoo/?$ modules/settings/odoo/index.php [L]
RewriteRule ^settings/jira/?$ modules/settings/jira/index.php [L]
RewriteRule ^settings/teams/?$ modules/settings/teams/index.php [L]
RewriteRule ^settings/sale-levels/?$ modules/settings/sale-levels/index.php [L]
RewriteRule ^settings/odoo-rates/?$ modules/settings/odoo_rates/index.php [L]
RewriteRule ^settings/backup/?$ modules/settings/backup/index.php [L]
RewriteRule ^settings/workflow/?$ modules/settings/workflow/index.php [L]
RewriteRule ^settings/arrowhitech/?$ modules/settings/arrowhitech/index.php [L]

# Application Modules
RewriteRule ^debt/?$ modules/debt/index.php [L]
RewriteRule ^my-debt/?$ modules/my_debt/index.php [L]
RewriteRule ^debt-warning/?$ modules/debt_warning/index.php [L]
RewriteRule ^customers/?$ modules/customers/index.php [L]
RewriteRule ^invoices/?$ modules/invoices/index.php [L]
RewriteRule ^kpi/?$ modules/kpi/index.php [L]
RewriteRule ^sale-orders/?$ modules/sale_orders/index.php [L]
RewriteRule ^my-reports/?$ modules/sale_reports/index.php [L]
RewriteRule ^detail-report/?$ modules/sale_reports/detail.php [L]
RewriteRule ^detail_report/?$ modules/sale_reports/detail.php [L]
RewriteRule ^sale-reports/?$ modules/sale_reports/index.php [L]
RewriteRule ^sale_reports/?$ modules/sale_reports/index.php [L]
RewriteRule ^sale-reports-admin/?$ modules/sale_reports_admin/index.php [L]

# HRM Module
RewriteRule ^hrm/?$ modules/hrm/index.php [L]
RewriteRule ^hrm/e-hiring/?$ modules/hrm/e_hiring.php [L]
RewriteRule ^hrm/company-info/?$ modules/hrm/company_info.php [L]
RewriteRule ^hrm/permissions/?$ modules/hrm/permissions.php [L]
RewriteRule ^hrm/proposal-settings/?$ modules/hrm/proposal_settings.php [L]
RewriteRule ^hrm/other-settings/?$ modules/hrm/other_settings.php [L]
RewriteRule ^hrm/candidate-sources/?$ modules/hrm/candidate_sources.php [L]
RewriteRule ^hrm/rejection-reasons/?$ modules/hrm/rejection_reasons.php [L]
RewriteRule ^hrm/expired-job-settings/?$ modules/hrm/expired_job_settings.php [L]
RewriteRule ^hrm/evaluation-criteria/?$ modules/hrm/evaluation_criteria.php [L]
RewriteRule ^hrm/job-post-create/?$ modules/hrm/job_post_create.php [L]
RewriteRule ^hrm/system-settings/?$ modules/hrm/system_settings.php [L]
RewriteRule ^hrm/ajax-handler/?$ modules/hrm/ajax_handler.php [L]

# Presale Module
RewriteRule ^projects/ceo-review/?$ modules/projects/ceo_review.php [L]
RewriteRule ^presale/?$ modules/presale/index.php [L]
RewriteRule ^presale/ajax-handler/?$ modules/presale/ajax_handler.php [L]
RewriteRule ^presale/vision/thumbnails/(.+)$ modules/presale/vision/thumbnails/$1 [L]

# APIs
RewriteRule ^api/request_production_plan/?$ api/request_production_plan.php [L]
RewriteRule ^api/pasx/callback/?$ api/pasx_callback.php [L]
RewriteRule ^api/notifications/mark_read/?$ api/notifications_mark_read.php [L]
RewriteRule ^api/kpi_tab_order/?$ api/kpi_tab_order.php [L]
RewriteRule ^api/kpi_monthly_save/?$ api/kpi_monthly_save.php [L]
RewriteRule ^api/kpi_quarterly_save/?$ api/kpi_quarterly_save.php [L]

# Allow direct access to vision thumbnails (before the modules block)
RewriteRule ^modules/presale/vision/thumbnails/(.+)$ modules/presale/vision/thumbnails/$1 [L]

# Protect modules directory from direct access (MUST be after all rewrite rules)
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^modules/ - [F,L]

# Home/Index: / -> index.php
DirectoryIndex index.php

# ============================================
# Security Headers
# ============================================
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>

# ============================================
# PHP Settings
# ============================================
<IfModule mod_php.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 10M
    php_value max_execution_time 300
    php_value max_input_time 300
</IfModule>

# ============================================
# Error Pages (optional)
# ============================================
# ErrorDocument 404 /404.php
# ErrorDocument 403 /403.php
# ErrorDocument 500 /500.php
